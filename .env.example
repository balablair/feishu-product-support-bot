# ── 飞书应用凭证（必填）──────────────────────────────────────────────────────
# 前往 https://open.feishu.cn/app 创建企业自建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 产品名称（用于 AI 过滤判断）──────────────────────────────────────────────
# 填写你的产品名，bot 会只回复与该产品相关的消息
PRODUCT_NAME=你的产品名称

# ── 文字对话 AI（必填）───────────────────────────────────────────────────────
# 支持任何 OpenAI 兼容 API（DeepSeek、OpenAI、Moonshot、智谱等）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 默认使用 DeepSeek，如需切换模型请修改以下两项
OPENAI_API_URL=https://api.deepseek.com/v1/chat/completions
OPENAI_MODEL=deepseek-chat

# ── 图片理解 AI（可选）───────────────────────────────────────────────────────
# 留空则不启用图片分析功能，填写后支持用户发送截图/图片
# 默认使用阿里云 Qwen-VL，需在阿里云百炼平台申请
VISION_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 向量检索 RAG（推荐开启）──────────────────────────────────────────────────
# 启用后知识库将按语义检索，每次只发相关片段给 AI，节省 token 并提升准确率
# 默认复用 VISION_API_KEY（同一阿里云账号），也可单独填写
# 留空则退回到全量知识库模式
EMBEDDING_API_KEY=
# 以下为默认值，使用阿里云 text-embedding-v3，一般无需修改
# EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
# EMBEDDING_MODEL=text-embedding-v3
# RAG_TOP_K=5
# RAG_CHUNK_SIZE=800

# ── 飞书多维表格（可选，用于自动收集用户反馈）────────────────────────────────
# 留空则关闭反馈收集功能
# 在飞书多维表格中创建表格后，从 URL 中获取 app_token 和 table_id
BITABLE_APP_TOKEN=
BITABLE_TABLE_ID=
# 反馈默认负责人的飞书 open_id（可留空）
FEEDBACK_DEFAULT_ASSIGNEE=

# ── 飞书云文档知识库（可选）──────────────────────────────────────────────────
# 多个文档 token 用英文逗号分隔，支持普通文档和 Wiki 页面
# 从文档 URL 中获取 token 部分
FEISHU_DOC_TOKENS=

# ── 飞书 Wiki Space 知识库（可选）────────────────────────────────────────────
# 填写 Wiki 任意页面的 token（从页面 URL 末尾获取），
# bot 会自动遍历整个 Space 并加载所有文档
# 例：https://xxx.feishu.cn/wiki/YLaCwu5OgiF1UGkEF2gcQTKkn8b → 填 YLaCwu5OgiF1UGkEF2gcQTKkn8b
# 所需权限：wiki:wiki:readonly（在飞书开放平台应用权限页开启）
#           并将机器人添加为 Wiki Space 成员（Wiki 设置 → 成员管理 → 添加机器人）
FEISHU_WIKI_TOKEN=

# ── 对话上下文配置（可选，有默认值）──────────────────────────────────────────
# 每段对话保留的轮数（1 轮 = 1条用户消息 + 1条 bot 回复）
MAX_HISTORY_TURNS=10
# 无活动后多少秒重置对话上下文（默认 30 分钟）
HISTORY_TTL=1800

# ── 管理员配置（可选）────────────────────────────────────────────────────────
# 可使用 /reload 等管理指令的用户 open_id，逗号分隔
# 在飞书中将鼠标悬停在用户头像上，或通过 API 获取 open_id
ADMIN_OPEN_IDS=
