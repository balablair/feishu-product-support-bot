# ── 飞书应用凭证（必填）──────────────────────────────────────────────────────
# 前往 https://open.feishu.cn/app 创建企业自建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 产品名称（用于 AI 过滤判断）──────────────────────────────────────────────
# 填写你的产品名，bot 会只回复与该产品相关的消息
PRODUCT_NAME=你的产品名称

# ── 文字对话 AI（必填）───────────────────────────────────────────────────────
# 支持任何 OpenAI 兼容 API（DeepSeek、OpenAI、Moonshot、智谱等）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 默认使用 DeepSeek，如需切换模型请修改以下两项
OPENAI_API_URL=https://api.deepseek.com/v1/chat/completions
OPENAI_MODEL=deepseek-chat

# ── 图片理解 AI（可选）───────────────────────────────────────────────────────
# 留空则不启用图片分析功能，填写后支持用户发送截图/图片
# 默认使用阿里云 Qwen-VL，需在阿里云百炼平台申请
VISION_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 飞书多维表格（可选，用于自动收集用户反馈）────────────────────────────────
# 留空则关闭反馈收集功能
# 在飞书多维表格中创建表格后，从 URL 中获取 app_token 和 table_id
BITABLE_APP_TOKEN=
BITABLE_TABLE_ID=
# 反馈默认负责人的飞书 open_id（可留空）
FEEDBACK_DEFAULT_ASSIGNEE=

# ── 飞书云文档知识库（可选）──────────────────────────────────────────────────
# 多个文档 token 用英文逗号分隔，支持普通文档和 Wiki 页面
# 从文档 URL 中获取 token 部分
FEISHU_DOC_TOKENS=
